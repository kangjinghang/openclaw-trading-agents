{
  "name": "openclaw-trading-agents",
  "version": "0.1.0",
  "description": "Multi-agent A-share stock analysis with debate-driven decision making for OpenClaw",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "scripts/setup-python.sh",
    "requirements.txt"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "analyze": "node dist/cli.js",
    "dashboard": "node dist/dashboard.js",
    "prepare": "husky || true"
  },
  "bin": {
    "trading-agents": "dist/cli.js"
  },
  "dependencies": {
    "openai": "4.104.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.19.19",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "lint-staged": "16.1.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "3.2.6"
  },
  "keywords": [
    "openclaw",
    "trading",
    "a-share",
    "stock-analysis",
    "multi-agent"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "bash -c 'npx tsc --noEmit'"
    ]
  }
}
