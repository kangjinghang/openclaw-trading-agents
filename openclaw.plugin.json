{
  "id": "trading-agents",
  "name": "Trading Agents - A股多角色分析",
  "version": "0.1.0",
  "description": "Multi-agent A-share stock analysis with debate-driven decision making",
  "main": "dist/index.js",
  "skills": [
    "./skills/trading-kline",
    "./skills/trading-analysis"
  ],
  "configSchema": {
    "models": { "type": "object" },
    "debate_rounds": { "type": "number", "default": 2 },
